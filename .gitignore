# Runtime backups created by antenna-cli during destructive ops
antenna-config.json.bak.*
antenna-peers.json.bak.*
antenna-inbox.json.bak.*

# Retired secrets (moved out of secrets/ during cleanup, never shipped)
secrets.retired/
